# CubeSandbox gateway (agent execution in disposable microVMs)
# Get these from your CubeSandbox gateway operator.
CUBESANDBOX_GATEWAY_URL=https://sandbox-gateway.rachpradhan.workers.dev
CUBESANDBOX_TENANT_KEY=demo-key-changeme

# Model provider key — injected into the microVM as an env var.
# Get via `graff key set kimi <key>` or from your provider dashboard.
KIMI_API_KEY=

# Agent model (must be available on your provider)
LAWPLAIN_AGENT_MODEL=kimi-k2.7

# Optional: override the graff binary download URL (defaults to v0.0.15 x86_64 linux)
# GRAFF_DOWNLOAD_URL=https://github.com/justrach/codegraff/releases/download/v0.0.15/graff-x86_64-linux.tar.gz

# Optional: use local graff subprocess instead of CubeSandbox (leave unset to use sandbox)
# To use local: unset CUBESANDBOX_* vars and set LAWGRAFF_BINARY=/path/to/graff
