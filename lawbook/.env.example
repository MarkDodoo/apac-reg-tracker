# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# Optional comma-separated extra origins for local/preview deployments.
BETTER_AUTH_TRUSTED_ORIGINS=http://127.0.0.1:3000,http://127.0.0.1:3002,http://localhost:3002

# Google Cloud Console OAuth 2.0 Web application credentials.
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Ask is opt-in, including locally. Local fallback runs graff --yolo on this
# trusted development machine; production is configured to use CubeSandbox.
LAWPLAIN_ASK_AGENT_ENABLED=true
LAWPLAIN_PUBLIC_HOST=localhost
LAWPLAIN_AGENT_CREDENTIAL=CODEGRAFF_API_KEY
CODEGRAFF_API_KEY=
# Required only to exercise the CubeSandbox path locally.
CUBESANDBOX_GATEWAY_URL=
CUBESANDBOX_TENANT_KEY=

# Cloudflare D1 is exposed through the AUTH_DB binding in wrangler.jsonc.
# Create it with: bun run d1:create

# APAC Regulation Tracker backend (pipeline/). When set, Ask uses local RAG
# instead of the graff legal agent.
REG_TRACKER_API_URL=http://localhost:8000
